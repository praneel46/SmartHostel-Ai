SMART_HOSTEL_MAIL_ENABLED=true
SMART_HOSTEL_MAIL_USERNAME=your-smarthostel-sender@gmail.com
SMART_HOSTEL_MAIL_PASSWORD=your-16-character-gmail-app-password
SMART_HOSTEL_MAIL_FROM=SmartHostel AI <your-smarthostel-sender@gmail.com>
SMART_HOSTEL_SMTP_SERVER=smtp.gmail.com
SMART_HOSTEL_SMTP_PORT=587

# Optional real WhatsApp sending through Twilio.
# If these are empty, SmartHostelAI keeps a mock WhatsApp log in the admin dashboard.
SMART_HOSTEL_TWILIO_ACCOUNT_SID=
SMART_HOSTEL_TWILIO_AUTH_TOKEN=
SMART_HOSTEL_TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
